<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <!-- ── Custom header ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="24dp"
            android:paddingBottom="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.SmsGateway.Button.Secondary"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device Settings"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connect this device to your account"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- ── Server URL ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SERVER URL"
            android:textSize="10sp"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:inputType="textUri"
            android:hint="https://api.smsgateway.codewithvin.app"
            android:padding="14dp"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:background="@drawable/input_background"
            android:fontFamily="monospace"
            android:layout_marginBottom="20dp" />

        <!-- ── Device ID ──────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEVICE ID"
            android:textSize="10sp"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etDeviceId"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:inputType="textNoSuggestions"
            android:hint="24-char Device ID"
            android:padding="14dp"
            android:textSize="13sp"
            android:textColor="@color/indigo_soft"
            android:textColorHint="@color/text_muted"
            android:background="@drawable/input_background"
            android:fontFamily="monospace"
            android:layout_marginBottom="20dp" />

        <!-- ── Device Secret ──────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEVICE SECRET"
            android:textSize="10sp"
            android:textColor="@color/text_muted"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etDeviceSecret"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:inputType="textPassword"
            android:hint="Paste device secret from dashboard"
            android:padding="14dp"
            android:textSize="13sp"
            android:textColor="@color/green"
            android:textColorHint="@color/text_muted"
            android:background="@drawable/input_background"
            android:fontFamily="monospace"
            android:layout_marginBottom="10dp" />

        <!-- Warning card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_warning"
            android:padding="14dp"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The Device Secret is shown ONCE when you register a device on the dashboard. Store it safely — it cannot be recovered."
                android:textSize="12sp"
                android:textColor="@color/amber"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- ── Save — explicit white text, no allCaps ──────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.SmsGateway.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Credentials"
            android:textColor="#ffffff"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- ── Clear — explicit red text, no allCaps ──────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/Widget.SmsGateway.Button.Danger"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Clear All Credentials"
            android:textColor="@color/red"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
