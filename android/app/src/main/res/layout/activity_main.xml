<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <!-- ── App header ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="24dp"
            android:paddingBottom="4dp">

            <!-- Logo mark -->
            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="💬"
                android:textSize="18sp"
                android:gravity="center"
                android:background="@drawable/logo_bg"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SMS Gateway"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delivery Platform"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Settings button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                style="@style/Widget.SmsGateway.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Settings"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp" />

        <!-- ── Status card ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEVICE STATUS"
                android:textSize="10sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp" />

            <!-- Status row: dot + text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:id="@+id/ivStatusDot"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:src="@drawable/status_dot_amber"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Status indicator" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking…"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvDeviceId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvServer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/text_muted" />

            <TextView
                android:id="@+id/tvLastSync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ── Setup guide (NOT configured) ───────────────────────── -->
        <LinearLayout
            android:id="@+id/cardSetup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_warning"
            android:padding="18dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETUP REQUIRED"
                android:textSize="10sp"
                android:textColor="@color/amber"
                android:letterSpacing="0.15"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Copy the FCM token below\n2. Go to dashboard → Devices → Add Device\n3. Paste token, register, save the Device Secret\n4. Come back → Settings → enter Device ID + Secret"
                android:textSize="13sp"
                android:textColor="@color/amber"
                android:lineSpacingMultiplier="1.6" />
        </LinearLayout>

        <!-- ── FCM Token card ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FCM TOKEN"
                android:textSize="10sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.15"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvFcmToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading…"
                android:textSize="11sp"
                android:textColor="@color/indigo_soft"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:textIsSelectable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp" />

            <!-- Copy button: explicit white text, textAllCaps off -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopyToken"
                style="@style/Widget.SmsGateway.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Copy Token"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />
        </LinearLayout>

        <!-- ── Continuous Polling Toggle ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_vercel_card"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continuous Polling"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zero-delay background delivery"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPolling"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- ── Poll Now ────────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPollNow"
            style="@style/Widget.SmsGateway.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Poll Now"
            android:textColor="#ffffff"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="28dp" />

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This app runs silently in the background. WorkManager polls every 15 minutes as a fallback when FCM push is unavailable."
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:lineSpacingMultiplier="1.5"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
