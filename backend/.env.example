# ============================================================
# SMS Gateway Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
# Get from: Atlas Dashboard → Connect → Connect your application
MONGO_URI=mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/smsgateway?retryWrites=true&w=majority

# JWT (User Auth)
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d



# Upstash Redis
# Get from: Upstash console → your database → Details → Redis URL
REDIS_URL=rediss://default:xxxxxxxxxxxx@xxxxxx.upstash.io:6379

# Firebase Admin SDK
# Get from: Firebase console → Project Settings → Service accounts → Generate new private key
# Encode on Windows PowerShell:
#   [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("<path>/serviceAccount.json")) | Out-File -NoNewline firebase_b64.txt
# Then paste the content of firebase_b64.txt below
FIREBASE_SERVICE_ACCOUNT=

# CORS — comma-separated list of allowed origins
# Dev:  http://localhost:5173   (Vite dev server)
# Prod: https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# Frontend public URL (used for generating links, emails, etc.)
# Dev:  http://localhost:5173
# Prod: https://yourdomain.com
FRONTEND_URL=http://localhost:5173
