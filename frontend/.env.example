# ============================================================
# Frontend — Environment Example
# ============================================================
# Copy to .env (local) or .env.production (production build).
# ============================================================

# Backend API base URL
# Dev:  leave EMPTY — Vite proxy handles /api, /auth, /admin
# Prod: https://api.yourdomain.com
VITE_API_BASE_URL=

# Displayed in API Key integration code snippets
# Dev:  http://localhost:3000
# Prod: https://api.yourdomain.com
VITE_APP_PUBLIC_URL=http://localhost:3000
